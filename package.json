{
  "name": "mateoolarte.com",
  "private": true,
  "version": "7.0.0",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "build": "next build --experimental-app-only",
    "start": "next start",
    "lint:js": "eslint",
    "lint:css": "stylelint '**/*.css'",
    "lint": "bun run lint:js && bun run lint:css",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze": "ANALYZE=true bun run build",
    "security": "bun audit --audit-level=critical",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/react-dialog": "1.1.15",
    "@supabase/ssr": "0.10.0",
    "@supabase/supabase-js": "2.103.0",
    "next": "16.2.2",
    "next-intl": "4.9.0",
    "posthog-js": "1.364.6",
    "posthog-node": "5.28.11",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/eslintrc": "3.3.5",
    "@next/bundle-analyzer": "16.2.2",
    "@playwright/test": "1.59.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-sonarjs": "3.0.7",
    "eslint-plugin-unicorn": "62.0.0",
    "husky": "9.1.7",
    "jsdom": "27.4.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "stylelint": "16.26.1",
    "stylelint-config-standard": "39.0.1",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.2"
  }
}
